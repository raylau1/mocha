{ name: "peri",
  type: "xbar",
  clock: "clk_i", // Main clock, used in sockets
  clock_connections: {
    clk_i: "main",
  },
  reset: "rst_ni",
  reset_connections: {
    rst_ni: "main",
  },
  nodes: [
    { name:  "axi_xbar", // Load store unit
      type:  "host",
      clock: "clk_i",
      reset: "rst_ni",
      addr_space: "hart",
      xbar:  true,
      pipeline: false,
    },
    { name:  "uart", // UART
      type:  "device",
      clock: "clk_i",
      reset: "rst_ni",
      xbar:  false,
      addr_range: [{
        base_addrs: {
          hart: "0x41000000",
        },
        size_byte: "0x00001000",
      }],
    },
    { name:  "spi_device", // SPI device
      type:  "device",
      clock: "clk_i",
      reset: "rst_ni",
      xbar:  false,
      addr_range: [{
        base_addrs: {
          hart: "0x43000000",
        },
        size_byte: "0x00002000",
      }],
    },
    { name:  "timer", // Timer
      type:  "device",
      clock: "clk_i",
      reset: "rst_ni",
      xbar:  false,
      addr_range: [{
        base_addrs: {
          hart: "0x44000000",
        },
        size_byte: "0x00010000",
      }],
    },
    { name:  "plic", // PLIC
      type:  "device",
      clock: "clk_i",
      reset: "rst_ni",
      xbar:  false,
      addr_range: [{
        base_addrs: {
          hart: "0x48000000",
        },
        size_byte: "0x04000000",
      }],
    },
  ],
  connections: {
    axi_xbar: [
      "uart",
      "spi_device",
      "timer",
      "plic"
    ],
  },
}


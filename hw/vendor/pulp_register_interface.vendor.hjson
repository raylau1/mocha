{
  name: "pulp_register_interface",
  target_dir: "pulp_register_interface",
  patch_dir: "patches/pulp_register_interface",

  upstream: {
    url: "https://github.com/pulp-platform/register_interface.git",
    rev: "master",
  },

  exclude_from_upstream: [
    // CI configurations.
    ".github",
    ".gitlab-ci.yml",
    // External dependencies.
    "vendor",
    // Deprecated sources.
    "src/deprecated"
  ]
}
